            </TabPane>
            <Separator layoutX="-7.0" layoutY="174.0" prefHeight="12.0" prefWidth="248.0" />
            <ImageView fitHeight="150.0" fitWidth="200.0" layoutX="42.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../asset/icon.png" />
